---
interface Props {
  title: string;
  description: string;
  slug: string;
  Icon: any;
}

const { title, description, slug, Icon } = Astro.props;
---

<a href={`/services/${slug}`} class="group block relative p-8 rounded-2xl bg-brand-card border border-white/8 transition-all duration-500 hover:border-white/20 hover:bg-white/5 overflow-hidden">
  <!-- Subtle hover glow -->
  <div class="absolute inset-0 bg-white/0 group-hover:bg-white/3 transition-all duration-500 rounded-2xl pointer-events-none"></div>

  <!-- Icon -->
  <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 text-brand-fg mb-6 transition-all group-hover:bg-white/10 group-hover:border-white/20">
    <Icon size={22} strokeWidth={1.5} />
  </div>

  <!-- Content -->
  <h3 class="text-xl font-heading font-bold text-brand-fg mb-3 tracking-tight uppercase">
    {title}
  </h3>

  <p class="text-brand-muted font-light leading-relaxed text-sm">
    {description}
  </p>

  <!-- CTA row -->
  <div class="mt-8 flex items-center text-brand-fg/40 text-[10px] font-mono uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity duration-300 gap-2">
    Découvrir l'expertise
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </div>
</a>
