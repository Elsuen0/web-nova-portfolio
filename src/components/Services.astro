---
import ServiceCard from './ServiceCard.astro';
import { services } from '../data/services';
---

<section id="services" class="py-28 px-6 max-w-7xl mx-auto">
	<!-- Section header -->
	<div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 md:gap-12 mb-12 md:mb-20 scroll-reveal">
		<div class="max-w-2xl">
			<span class="text-brand-muted font-mono uppercase tracking-[0.2em] text-[10px]">Expertises</span>
			<h2 class="text-4xl md:text-6xl font-heading font-bold text-brand-fg mt-4 leading-[1.1] tracking-tight uppercase">
				Des solutions pointues pour<br/>
				<span class="text-brand-muted">des ambitions illimitées.</span>
			</h2>
		</div>
		<p class="max-w-xs text-brand-muted font-light leading-relaxed">
			Créativité artistique et rigueur technique, au service de vos projets les plus ambitieux.
		</p>
	</div>

	<!-- Cards grid -->
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
		{services.map((service, index) => (
			<div class="scroll-reveal" style={`transition-delay: ${index * 100}ms`}>
				<ServiceCard {...service} />
			</div>
		))}
	</div>
</section>

