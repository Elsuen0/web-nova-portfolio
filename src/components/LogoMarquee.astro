---
const partners = [
  { name: 'Astro', logo: 'https://cdn.simpleicons.org/astro/FF5D01' },
  { name: 'Tailwind CSS', logo: 'https://cdn.simpleicons.org/tailwindcss/06B6D4' },
  { name: 'React', logo: 'https://cdn.simpleicons.org/react/61DAFB' },
  { name: 'Vercel', logo: 'https://cdn.simpleicons.org/vercel/white' },
  { name: 'Node.js', logo: 'https://cdn.simpleicons.org/nodedotjs/5FA04E' },
  { name: 'TypeScript', logo: 'https://cdn.simpleicons.org/typescript/3178C6' },
];
---

<div class="py-12 border-y border-white/5 bg-brand-card/20 overflow-hidden relative">
  <!-- Gradient side masks -->
  <div class="absolute inset-y-0 left-0 w-32 bg-linear-to-r from-brand-bg to-transparent z-10 pointer-events-none"></div>
  <div class="absolute inset-y-0 right-0 w-32 bg-linear-to-l from-brand-bg to-transparent z-10 pointer-events-none"></div>

  <div class="animate-marquee flex gap-24 items-center">
    {[...partners, ...partners, ...partners, ...partners].map((partner, i) => (
      <div class="flex items-center gap-5 group transition-all duration-300">
        <div class="w-9 h-9 flex items-center justify-center transition-all duration-500 transform group-hover:scale-115 group-hover:drop-shadow-[0_0_15px_rgba(255,255,255,0.15)]">
          <img 
            src={partner.logo} 
            alt={partner.name} 
            class="w-full h-full object-contain transition-all duration-500" 
            loading="lazy" 
          />
        </div>
        <span class="text-[10px] font-mono font-bold uppercase tracking-[0.3em] text-brand-muted/40 group-hover:text-brand-fg transition-colors duration-300 whitespace-nowrap">
          {partner.name}
        </span>
      </div>
    ))}
  </div>
</div>
