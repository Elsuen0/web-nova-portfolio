---

<nav
  class="fixed top-0 inset-x-0 z-[70] px-6 py-5 flex items-center justify-between border-b border-white/5 bg-brand-bg/80 backdrop-blur-md"
>
  <a
    href="/"
    id="nav-logo"
    class="text-brand-fg font-heading font-bold text-lg tracking-tight uppercase z-50"
  >
    Web Nova <span class="text-brand-muted font-light">Solutions</span>
  </a>

  <!-- Desktop Menu -->
  <div
    class="hidden md:flex items-center gap-8 text-[11px] font-mono uppercase tracking-widest text-brand-muted"
  >
    <a href="/#services" class="hover:text-brand-fg transition-colors"
      >Services</a
    >
    <a href="/#projets" class="hover:text-brand-fg transition-colors"
      >Réalisations</a
    >
    <a href="/#avis" class="hover:text-brand-fg transition-colors">Avis</a>
    <a href="/#contact" class="hover:text-brand-fg transition-colors">Contact</a
    >
    <a
      href="mailto:contact@webnovasolutions.fr"
      class="ml-4 px-6 py-2.5 bg-brand-fg text-brand-bg rounded-full font-bold hover:scale-105 transition-transform"
    >
      Parlons-en →
    </a>
  </div>

  <!-- Mobile Menu Button -->
  <button
    id="menu-toggle"
    class="md:hidden relative z-50 p-2 text-brand-fg transition-colors"
    aria-label="Menu"
  >
    <div class="w-6 h-5 flex flex-col justify-between overflow-hidden">
      <span
        class="w-full h-0.5 bg-current transition-transform duration-300 origin-left"
      ></span>
      <span class="w-full h-0.5 bg-current transition-opacity duration-300"
      ></span>
      <span
        class="w-full h-0.5 bg-current transition-transform duration-300 origin-left"
      ></span>
    </div>
  </button>
</nav>

<!-- Mobile Menu Drawer -->
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 w-full h-full z-60 flex-col hidden bg-[#0f1115]"
>
  <!-- Texture overlay -->
  <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none"></div>

  <div class="relative z-10 flex flex-col h-full px-8 pt-32 pb-12 overflow-y-auto">
    <!-- Links -->
    <nav class="flex flex-col gap-8">
      <a href="/#services" class="mobile-link text-4xl font-heading font-bold uppercase tracking-tight text-brand-fg">Services</a>
      <a href="/#projets" class="mobile-link text-4xl font-heading font-bold uppercase tracking-tight text-brand-fg">Réalisations</a>
      <a href="/#avis" class="mobile-link text-4xl font-heading font-bold uppercase tracking-tight text-brand-fg">Avis</a>
      <a href="/#contact" class="mobile-link text-4xl font-heading font-bold uppercase tracking-tight text-brand-fg">Contact</a>

      <div class="mt-4">
        <a
          href="mailto:contact@webnovasolutions.fr"
          class="inline-flex px-8 py-4 bg-brand-fg text-brand-bg rounded-full text-xs font-mono uppercase tracking-widest font-bold items-center gap-2"
        >
          Parlons-en →
        </a>
      </div>
    </nav>

    <!-- Menu Footer -->
    <div class="mt-auto pt-12 border-t border-white/5">
      <div class="flex flex-col gap-8">
        <div>
          <p class="text-[10px] font-mono text-brand-muted uppercase tracking-[0.3em] mb-4">
            Suivez l'aventure
          </p>
          <div class="flex gap-6 text-brand-fg/60 text-[11px] font-mono uppercase tracking-widest">
            <a href="https://www.linkedin.com/in/lucas-capart/" class="hover:text-brand-fg">LinkedIn</a>
            <a href="https://github.com/Elsuen0" class="hover:text-brand-fg">GitHub</a>
          </div>
        </div>

        <div class="flex justify-between items-end">
          <div class="space-y-1">
            <p class="text-[10px] font-mono text-brand-muted uppercase tracking-[0.3em]">Contact</p>
            <p class="text-xs text-brand-fg font-light">Amiens, France / Remote</p>
          </div>
          <p class="text-[8px] font-mono text-brand-muted uppercase tracking-[0.2em]">© 2026 WEB NOVA</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  const spans = menuToggle?.querySelectorAll("span");

  let isOpen = false;

  const toggleMenu = () => {
    isOpen = !isOpen;
    if (mobileMenu && spans) {
      if (isOpen) {
        mobileMenu.classList.remove("hidden");
        mobileMenu.classList.add("flex");
      } else {
        mobileMenu.classList.remove("flex");
        mobileMenu.classList.add("hidden");
      }

      document.body.style.overflow = isOpen ? "hidden" : "";

      // Animate hamburger (kept simple rotate)
      spans[0].style.transform = isOpen ? "rotate(45deg) translate(2px, -1px)" : "";
      spans[1].style.opacity = isOpen ? "0" : "1";
      spans[2].style.transform = isOpen ? "rotate(-45deg) translate(2px, 1px)" : "";
    }
  };

  menuToggle?.addEventListener("click", toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isOpen) toggleMenu();
    });
  });
</script>

<style>
  .grid-bg {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>

