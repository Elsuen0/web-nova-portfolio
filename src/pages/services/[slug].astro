---
import Layout from '../../components/Layout.astro';
import Footer from '../../components/Footer.astro';
import { services } from '../../data/services';
import { ArrowLeft, CheckCircle2 } from 'lucide-react';

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const Icon = service.Icon;
---

<Layout title={`${service.title} | Web Nova Solutions`} description={service.description}>
  <main class="relative pt-32 pb-20 px-6 overflow-hidden">
    <!-- Decorative background -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-white/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-white/3 rounded-full blur-[80px]"></div>
    </div>

    <div class="max-w-5xl mx-auto">
      <!-- Back button -->
      <a href="/#services" class="inline-flex items-center gap-2 text-brand-muted hover:text-brand-fg transition-colors mb-12 group text-xs font-mono uppercase tracking-widest scroll-reveal">
        <ArrowLeft size={14} class="transition-transform group-hover:-translate-x-1" />
        Retour aux services
      </a>

      <!-- Header -->
      <div class="flex flex-col md:flex-row items-start md:items-center gap-8 mb-20 scroll-reveal">
        <div class="w-20 h-20 flex items-center justify-center rounded-2xl bg-brand-card border border-white/10 text-brand-fg shrink-0 shadow-2xl">
          <Icon size={40} strokeWidth={1} />
        </div>
        <div>
          <span class="text-brand-muted font-mono uppercase tracking-[0.2em] text-[10px]">Expertise de pointe</span>
          <h1 class="text-5xl md:text-7xl font-heading font-bold text-brand-fg mt-2 leading-[0.9] uppercase tracking-tighter">
            {service.title}
          </h1>
        </div>
      </div>

      <!-- Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <div class="lg:col-span-8 space-y-24">
          
          <section class="scroll-reveal">
            <p class="text-2xl md:text-3xl text-brand-fg font-light leading-snug">
              {service.detailedDescription}
            </p>
          </section>

          <div class="h-px bg-white/5 w-full"></div>

          <!-- Benefits Grid -->
          <section class="space-y-12 scroll-reveal">
            <h2 class="text-sm font-mono font-bold text-brand-fg uppercase tracking-[0.3em] flex items-center gap-3">
              <span class="w-8 h-px bg-brand-fg/30"></span> Vos Avantages
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {service.benefits.map((benefit) => (
                <div class="flex items-start gap-4 p-6 rounded-2xl bg-brand-card border border-white/5 hover:border-white/10 transition-colors">
                  <CheckCircle2 size={24} class="text-brand-fg shrink-0 mt-0.5" />
                  <span class="text-base text-brand-muted font-light leading-relaxed">{benefit}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Process Section -->
          <section class="space-y-12 scroll-reveal">
            <h2 class="text-sm font-mono font-bold text-brand-fg uppercase tracking-[0.3em] flex items-center gap-3">
              <span class="w-8 h-px bg-brand-fg/30"></span> Notre Processus
            </h2>
            <div class="space-y-4">
              {service.process.map((step, i) => (
                <div class="flex items-center gap-6 p-6 rounded-2xl bg-white/[0.02] border border-white/5 group hover:bg-white/[0.04] transition-colors">
                  <span class="text-4xl font-heading font-bold text-white/5 group-hover:text-white/10 transition-colors">0{i + 1}</span>
                  <span class="text-lg text-brand-fg font-medium tracking-tight uppercase">{step}</span>
                </div>
              ))}
            </div>
          </section>
        </div>

        <!-- Sidebar / Contact -->
        <div class="lg:col-span-4">
          <div class="p-10 rounded-3xl bg-brand-card border border-white/10 sticky top-32 shadow-3xl scroll-reveal">
            <h3 class="text-xl font-heading font-bold text-brand-fg mb-6 uppercase tracking-tight leading-tight">Prêt à transformer<br/>votre vision ?</h3>
            <p class="text-sm text-brand-muted font-light mb-10 leading-relaxed">
              Une expertise technique rare au service de votre croissance. Discutons de vos objectifs lors d'un premier appel gratuit.
            </p>
            <a href="mailto:contact@webnovasolutions.fr" class="block w-full py-5 bg-brand-fg text-brand-bg rounded-full font-bold text-sm text-center transform hover:scale-[1.03] active:scale-[0.97] transition-all shadow-xl">
              Démarrer le projet
            </a>
            <div class="mt-8 pt-8 border-t border-white/5 flex flex-col gap-4">
              <div class="flex items-center gap-3 text-brand-muted/60">
                 <div class="w-2 h-2 rounded-full bg-green-500"></div>
                 <span class="text-[10px] font-mono uppercase tracking-widest">Disponible maintenant</span>
              </div>
              <p class="text-[9px] text-brand-muted/40 font-mono uppercase tracking-[0.2em]">Réponse garantie sous 24 heures</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
